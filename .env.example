# Copy this file to .env and fill in the values.
# Never commit .env — it's gitignored for a reason.

ENVIRONMENT=local
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://spendlens:spendlens@postgres:5432/spendlens
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# Redis
REDIS_URL=redis://redis:6379/0

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=1440

# Object storage (MinIO locally, S3 in prod)
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=receipts
S3_ACCESS_KEY=spendlens
S3_SECRET_KEY=spendlens-secret
S3_REGION=us-east-1

# OpenAI — optional; app falls back to rule-based categorisation without it
OPENAI_API_KEY=
OPENAI_MODEL_CATEGORISE=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o

# OCR
OCR_CONFIDENCE_THRESHOLD=60

# CORS — comma-separated list mapped via pydantic
CORS_ORIGINS=["http://localhost:3000"]
